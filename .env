# GitHub token for GitHub Models / Azure OpenAI compatible endpoint.
# Paste your token value here.
GITHUB_TOKEN=

# Model from https://github.com/marketplace/models/azure-openai/text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# Optional override. Default used if empty:
# https://models.inference.ai.azure.com/embeddings
GITHUB_EMBEDDINGS_URL=
